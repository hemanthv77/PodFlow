# PodFlow Configuration
# Copy: cp .env.example .env

APP_NAME=PodFlow

# Database: sqlite (dev) or postgresql (prod)
DB_BACKEND=sqlite
DATABASE_PATH=data/podflow.db

# PostgreSQL (only when DB_BACKEND=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=podflow
DB_USER=podflow
DB_PASSWORD=podflow

# Paths
DOWNLOAD_DIR=downloads

# RSS
RSS_URL=https://www.marketplace.org/feed/podcast/marketplace/

# Download
DOWNLOAD_TIMEOUT=120
DOWNLOAD_MAX_RETRIES=3

# RSS Fetch
RSS_FETCH_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
